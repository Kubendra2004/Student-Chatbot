# Runtime data backend mode: local | sheetdb
DATA_MODE=sheetdb

# Required when DATA_MODE=sheetdb
SHEETDB_API_URL=https://sheetdb.io/api/v1/YOUR_API_ID

# Used when DATA_MODE=local
# Frontend local mode calls this Python local API server.
LOCAL_API_URL=http://127.0.0.1:8001

# Local API server settings
LOCAL_API_HOST=127.0.0.1
LOCAL_API_PORT=8001

# Excel backend path for local API and CLI
LOCAL_EXCEL_PATH=chat.xlsx
